datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  passwordHash       String
  role               String        // "PATIENT", "DOCTOR", "HOSPITAL_ADMIN", "SYSTEM_ADMIN"
  isVerified         Boolean       @default(false)
  verificationToken  String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  patient            Patient?
  doctor             Doctor?
  auditLogs          AuditLog[]
  notifications      Notification[]
  sessions           Session[]
  devices            Device[]
}

model Patient {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  age                Int
  gender             String
  height             Float              // in cm
  weight             Float              // in kg
  procedure          String
  hospital           String
  surgeon            String
  medicalHistory     String             // Encrypted/Structured JSON string
  comorbidities      String             // Comorbidities list (comma-separated or JSON)
  emergencyContact   String             // Contact details JSON string
  recoveryPassportId String?            @unique
  recoveryPassport   RecoveryPassport?
  clinicalMemories   ClinicalMemory[]
  documents          Document[]
  images             Image[]
  recoveryTwin       RecoveryTwin?
  tasks              Task[]
  consent            Consent?
  feedbacks          DoctorFeedback[]
  appointments       Appointment[]
  recoveryStatus     String             @default("ACTIVE") // ACTIVE, RECOVERED, COMPLICATED
}

model Doctor {
  id             String           @id @default(uuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  specialty      String
  hospital       String
  licenseNumber  String
  feedbacks      DoctorFeedback[]
  appointments   Appointment[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model RecoveryPassport {
  id                   String            @id @default(uuid())
  patientId            String            @unique
  patient              Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  currentRecoveryScore Float             @default(100.0)
  status               String            @default("ACTIVE") // ACTIVE, RECOVERED, COMPLICATED
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  versions             RecoveryVersion[]
  blockchainRecords    BlockchainRecord[]
}

model RecoveryVersion {
  id                     String             @id @default(uuid())
  passportId             String
  passport               RecoveryPassport   @relation(fields: [passportId], references: [id], onDelete: Cascade)
  versionNumber          Int
  timestamp              DateTime           @default(now())
  healingScore           Float
  inflammationScore      Float
  swellingScore          Float
  painLevel              Int
  medicationAdherence    Float              // percentage (0 to 100)
  clinicalMemorySnapshot String             // JSON string representation of clinical memory at this point
  doctorNotes            String
  aiSummary              String
  recoveryScore          Float
  evidenceSnapshot       String             // Explainability JSON (clinical factors, references)
  recommendations        String             // JSON string list of intervention recommendations
  interventions          String             // JSON string list of action items
  doctorDecisions        String             // JSON string of reviewed actions
  uploadedImages         String             // JSON string list of image paths
  visionAnalysis         String             // JSON string of vision AI results
  images                 Image[]
  blockchainRecords      BlockchainRecord[]
}

model ClinicalMemory {
  id                 String     @id @default(uuid())
  patientId          String
  patient            Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedure          String
  procedureDate      DateTime
  diagnosis          String
  implants           String     // JSON or text
  comorbidities      String     // JSON or text
  allergies          String     // JSON or text
  medications        String     // JSON or text
  restrictions       String     // JSON or text
  riskFactors        String     // JSON or text
  previousSurgeries  String     // JSON or text
  labValues          String     // JSON or text
  followUpSchedule   String     // JSON or text
  doctorInstructions String     // JSON or text
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Document {
  id              String         @id @default(uuid())
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name            String
  type            String         // DISCHARGE_SUMMARY, PRESCRIPTION, BLOOD_REPORT, LAB_REPORT, RADIOLOGY_REPORT, OPERATION_NOTES, FOLLOWUP_NOTES
  path            String
  size            Int
  status          String         // UPLOADED, PARSED, FAILED
  parsedMemoryId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Image {
  id              String           @id @default(uuid())
  patientId       String
  patient         Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  versionId       String?
  version         RecoveryVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  path            String
  metadata        String           // Image size, format, compression status
  fileHash        String?          @unique // To prevent duplicate uploads
  createdAt       DateTime         @default(now())
}

model RecoveryTwin {
  id                             String   @id @default(uuid())
  patientId                      String   @unique
  patient                        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  expectedRecoveryCurve          String   // JSON representing array of { day, expectedScore }
  actualRecoveryCurve            String   // JSON representing array of { day, actualScore }
  deviationTimeline              String   // JSON representing array of { date, deviationScore, severity }
  projectedRecoveryCompletionDate DateTime
  deviationEvents                String   // JSON representing array of deviation objects
  recoveryTwinConfidence         Float
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model DoctorFeedback {
  id                     String   @id @default(uuid())
  recommendationId       String
  patientId              String
  patient                Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId               String
  doctor                 Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  originalRecommendation String   // JSON string of the original recommendation
  doctorAction           String   // ACCEPT, MODIFY, REJECT
  modifiedRecommendation String?  // JSON or text
  reason                 String
  doctorSpecialty        String
  outcome                String?  // Description of patient outcome
  createdAt              DateTime @default(now())
}

model Task {
  id                String   @id @default(uuid())
  patientId         String
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name              String   // e.g. "Take Paracetamol", "Walk 500m"
  type              String   // MEDICATION, WALKING, HYDRATION, EXERCISE, IMAGE_UPLOAD, APPOINTMENT
  description       String
  schedule          String   // e.g. "DAILY", "THREE_TIMES_A_DAY"
  reminders         String   // JSON string of time rules
  completionHistory String   // JSON string tracking execution list
  adherenceScore    Float    @default(100.0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  channel   String   // EMAIL, SMS, PUSH
  status    String   // PENDING, SENT, FAILED
  sentAt    DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userRole    String?
  action      String   // AUTH, UPLOAD, PREDICTION, REVIEW, ACCESS, UPDATE
  target      String
  ipAddress   String
  payloadHash String   // cryptographic hash of the content for tamper-proofing
  timestamp   DateTime @default(now())
}

model Consent {
  id          String   @id @default(uuid())
  patientId   String   @unique
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consentType String   // e.g. "CLINICAL_DATA_USE,RESEARCH_USE"
  granted     Boolean
  ipAddress   String
  signedAt    DateTime @default(now())
}

model BlockchainRecord {
  id               String           @id @default(uuid())
  passportId       String
  passport         RecoveryPassport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  versionId        String?
  version          RecoveryVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  consentHash      String
  predictionHash   String
  doctorReviewHash String
  modelVersion     String
  timestamp        DateTime         @default(now())
}

model Hospital {
  id        String   @id @default(uuid())
  name      String   @unique
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id              String   @id @default(uuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointmentDate DateTime
  status          String   // "SCHEDULED", "COMPLETED", "CANCELLED"
  notes           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String
  userAgent String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String   @unique
  deviceName String
  type       String   // MOBILE, DESKTOP
  isTrusted  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
